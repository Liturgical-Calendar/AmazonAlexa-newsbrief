#: src/LiturgyOfTheDay.php:597
msgid "Liturgy of the Day"
msgstr "Liturgia dnia"

#: src/LiturgyOfTheDay.php:656
msgid "Today is"
msgstr "Dzisiaj jest"

#. translators: 1. name of the festivity
#: src/LiturgyOfTheDay.php:662
#, php-format
msgid "This evening there will be a Vigil Mass for the %1$s."
msgstr "Dziś wieczorem odbędzie się msza czuwania w intencji %1$s."

#: src/LiturgyOfTheDay.php:663 src/LiturgyOfTheDay.php:671
msgid "Vigil Mass"
msgstr "Msza czuwania"

#. translators: 1. grade of the festivity, 2. name of the festivity
#: src/LiturgyOfTheDay.php:669
#, php-format
msgid "This evening there will be a Vigil Mass for the %1$s %2$s."
msgstr "Dziś wieczorem odbędzie się msza czuwania w intencji %1$s %2$s."

#. translators: 1. (also|''), 2. name of the festivity
#. translators: CTXT: Sundays. 1. (also|''), 2. name of the festivity
#. translators: CTXT: Saturday memorial BVM. 1. (also|''), 2. name of the festivity
#: src/LiturgyOfTheDay.php:679 src/LiturgyOfTheDay.php:697
#: src/LiturgyOfTheDay.php:713
#, php-format
msgid "Today is %1$s the %2$s."
msgstr "Dzisiaj jest %1$s %2$s."

#: src/LiturgyOfTheDay.php:680 src/LiturgyOfTheDay.php:687
#: src/LiturgyOfTheDay.php:698 src/LiturgyOfTheDay.php:705
#: src/LiturgyOfTheDay.php:714 src/LiturgyOfTheDay.php:722
#: src/LiturgyOfTheDay.php:736
msgid "also"
msgstr "również"

#. translators: 1. (also|''), 2. grade of the festivity, 3. name of the festivity
#. translators: CTXT: (optional) memorial or feast. 1. (also|''), 2. grade of the festivity, 3. name of the festivity
#: src/LiturgyOfTheDay.php:686 src/LiturgyOfTheDay.php:721
#, php-format
msgid "Today is %1$s the %2$s of %3$s."
msgstr "Dzisiaj jest %1$s %2$s z %3$s."

#. translators: CTXT: Feast of the Lord. 1. (also|''), 2. grade of the festivity, 3. name of the festivity
#: src/LiturgyOfTheDay.php:704
#, php-format
msgid "Today is %1$s the %2$s, %3$s."
msgstr "Dzisiaj jest %1$s %2$s, %3$s."

#. translators: CTXT: higher grade solemnity with precedence over other solemnities. 1. (also|''), 2. name of the festivity
#: src/LiturgyOfTheDay.php:735
#, php-format
msgid "Today is %1$s the day of %2$s."
msgstr "Dziś jest %1$s dzień %2$s."

